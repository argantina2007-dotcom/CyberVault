# Database connection used by SQLAlchemy. Use the driver appropriate for your deployment.
DATABASE_URL=mysql+pymysql://app_user:replace-with-a-strong-password@localhost:3306/cybervault

# Generate a unique, high-entropy value for each environment. Never commit the real key.
SECRET_KEY=replace-with-a-long-random-secret

# JWT configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated browser origins allowed to send credentialed requests.
CORS_ORIGINS=http://localhost:5173

# Authentication rate limits
LOGIN_RATE_LIMIT=5/minute
REGISTER_RATE_LIMIT=5/minute
REFRESH_RATE_LIMIT=10/minute
